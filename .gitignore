# Bytecode e cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribuições e empacotamento
.Python
build/
dist/
*.egg-info/
*.egg
.pip-cache/

# Ambientes virtuais
.venv/
venv/
env/
ENV/

# Variáveis de ambiente e segredos
.env
.env.*
!.env.example

# Testes e cobertura
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_meta

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Dados (CDS rule: nunca versionar dados brutos)
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Amostras pequenas são versionadas
!data/samples/

# Documentação externa baixada
references/**
!references/README.md

# Reports gerados
reports/figures/*
!reports/figures/.gitkeep

# Vetorstore Chroma
*.sqlite3
chroma_*/

# Arquivos geoespaciais grandes em qualquer lugar fora de samples
*.tif
*.tiff
*.nc
*.zarr
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.gpkg
*.geojson
!tests/data/**
!data/samples/**

# Modelos baixados localmente
models/
*.bin
*.safetensors
