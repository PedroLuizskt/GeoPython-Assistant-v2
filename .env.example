# =============================================================================
# GeoPython Assistant v2 - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# =============================================================================

# Chave de API da Groq (obtenha em https://console.groq.com/keys)
GROQ_API_KEY=

# Modelo LLM (opções recomendadas: llama-3.3-70b-versatile, openai/gpt-oss-20b)
GEOPY_LLM_MODEL=llama-3.3-70b-versatile

# Temperatura do modelo (0.0 a 1.0; valores baixos reduzem alucinação)
GEOPY_LLM_TEMPERATURE=0.2

# Máximo de tokens de saída
GEOPY_LLM_MAX_TOKENS=2048

# Modelo de embeddings (HuggingFace)
GEOPY_EMBEDDING_MODEL=sentence-transformers/msmarco-bert-base-dot-v5

# Diretório de persistência do vetorstore de documentação
GEOPY_DOCS_CHROMA_DIR=data/processed/chroma_docs

# Quantidade de chunks recuperados por consulta
GEOPY_RETRIEVER_K=4

# Nível de log (DEBUG, INFO, WARNING, ERROR)
GEOPY_LOG_LEVEL=INFO
